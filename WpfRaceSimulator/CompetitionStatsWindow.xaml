<Window x:Class="WpfRaceSimulator.CompetitionStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Competitie Statistieken"
        Height="450"
        Width="400">

    <Grid Margin="10">

        <GroupBox Header="Kampioenschapsstand">
            <ListBox ItemsSource="{Binding ChampionshipStandings}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Width="100"/>
                            <TextBlock Text="{Binding Points}" Width="50"/>
                            <TextBlock Text="punten"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

    </Grid>
</Window>