<Window x:Class="WpfRaceSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Race Simulator" Height="800" Width="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="170"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Background="LightGray">
            <Menu DockPanel.Dock="Top" Height="25">
                <MenuItem Header="Menu">
                    <MenuItem Header="Race statistieken" Click="MenuItem_RaceStats_Click"/>
                    <MenuItem Header="Competitie statistieken" Click="MenuItem_CompetitionStats_Click"/>
                    <Separator/>
                    <MenuItem Header="Afsluiten" Click="MenuItem_Exit_Click"/>
                </MenuItem>
            </Menu>

            <StackPanel Orientation="Horizontal" Margin="10,25,0,0">
                <Label Content="Huidige baan:" FontWeight="Bold"/>
                <Label Content="{Binding CurrentTrackName}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Image x:Name="TrackImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

            <Canvas x:Name="MainCanvas"
                    IsHitTestVisible="False"/>
        </Grid>

        <Grid Grid.Row="2" Background="#EEEEEE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Coureurs" Grid.Column="0" Margin="10">
                <ListBox ItemsSource="{Binding Drivers}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="80"/>
                                <TextBlock Text="Punten: "/>
                                <TextBlock Text="{Binding Points}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Header="Kampioenschap" Grid.Column="1" Margin="10">
                <ListBox ItemsSource="{Binding ChampionshipStandings}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="80"/>
                                <TextBlock Text=" - "/>
                                <TextBlock Text="{Binding Points}"/>
                                <TextBlock Text=" punten"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</Window>