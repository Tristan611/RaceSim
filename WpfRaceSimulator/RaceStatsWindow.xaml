<Window x:Class="WpfRaceSimulator.RaceStatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Race Statistieken"
        Height="400"
        Width="350">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding CurrentTrackName}"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Drivers}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" Width="100"/>
                        <TextBlock Text="Punten: "/>
                        <TextBlock Text="{Binding Points}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding BestOnPoints}"/>
            <TextBlock Text="{Binding FastestFinisher}"/>
        </StackPanel>
    </Grid>
</Window>